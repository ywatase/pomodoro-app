{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "tomatask main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "notification:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-read-dir"
  ]
}
