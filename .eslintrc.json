{
  "extends": ["eslint:recommended", "plugin:svelte/recommended"],
  "parserOptions": {
    "sourceType": "module",
    "ecmaVersion": 2022,
    "extraFileExtensions": [".svelte"]
  },
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "globals": {
    "$state": "readonly",
    "$derived": "readonly",
    "$effect": "readonly",
    "$props": "readonly",
    "$bindable": "readonly",
    "$inspect": "readonly",
    "$host": "readonly"
  }
}
